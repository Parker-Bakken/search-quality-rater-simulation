import pandas as pd
from pathlib import Path

# Paths
csv_path = Path("dataset/queries_labeled.csv")

# Load
df = pd.read_csv(csv_path)

# Basic checks
print("Rows:", len(df))
print("Columns:", list(df.columns))
print("\nMissing values:\n", df.isna().sum())

# Intent distribution
intent_counts = df["intent"].value_counts(dropna=False)
intent_pct = (intent_counts / len(df) * 100).round(1)

summary = pd.DataFrame({
    "count": intent_counts,
    "percent": intent_pct.astype(str) + "%"
})

print("\nIntent distribution:\n")
print(summary)

# Notes breakdown (optional)
if "notes" in df.columns:
    notes_counts = df["notes"].fillna("(blank)").value_counts().head(15)
    print("\nTop notes (first 15):\n")
    print(notes_counts)

# Save outputs for the repo (optional, makes it look more professional)
out_dir = Path("analysis/outputs")
out_dir.mkdir(parents=True, exist_ok=True)

summary.to_csv(out_dir / "intent_distribution.csv")
summary.to_markdown(out_dir / "intent_distribution.md")

print(f"\nSaved: {out_dir / 'intent_distribution.csv'}")
print(f"Saved: {out_dir / 'intent_distribution.md'}")
